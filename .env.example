# ===========================================
# Bankruptcy Academy - Environment Variables
# Скопируйте этот файл в .env и заполните значения
# ===========================================

# --- Сервер ---
SERVER_HOST=your-server-ip
SERVER_SSH_USER=root
SERVER_SSH_KEY=~/.ssh/id_rsa_bankruptcy_server

# --- PostgreSQL ---
DATABASE_HOST=your-server-ip
DATABASE_PORT=5432
DATABASE_NAME=bankruptcy_academy
DATABASE_USER=ba_app
DATABASE_PASSWORD=your-password
DATABASE_URL=postgresql://ba_app:your-password@your-server-ip:5432/bankruptcy_academy

# --- Backend API ---
API_PORT=3001
API_HOST=localhost
VITE_API_URL=http://localhost:3001/api

# --- JWT Secret ---
JWT_SECRET=change-this-in-production

# --- Загрузка файлов ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ==========================================
# КАК ПОЛУЧИТЬ ЭТИ ЗНАЧЕНИЯ:
# ==========================================
# 1. Перейди на https://dashboard.supabase.com
# 2. Выбери свой проект
# 3. Нажми на иконку настроек
# 4. Выбери "API" в левом меню
# 5. Скопируй:
#    - Project URL → VITE_SUPABASE_URL
#    - anon public → VITE_SUPABASE_ANON_KEY
