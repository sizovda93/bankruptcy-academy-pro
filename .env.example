# ==========================================
# SUPABASE CONFIGURATION
# ==========================================
# Получи эти значения из твоего проекта на https://dashboard.supabase.com

# Переименуй этот файл в .env.local и заполни значения

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ==========================================
# КАК ПОЛУЧИТЬ ЭТИ ЗНАЧЕНИЯ:
# ==========================================
# 1. Перейди на https://dashboard.supabase.com
# 2. Выбери свой проект
# 3. Нажми на иконку настроек
# 4. Выбери "API" в левом меню
# 5. Скопируй:
#    - Project URL → VITE_SUPABASE_URL
#    - anon public → VITE_SUPABASE_ANON_KEY
